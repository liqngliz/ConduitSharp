{
  "title": "ConduitSharp Gateway",
  "uid": "conduitsharp-gateway",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (route_id) (rate(conduitsharp_gateway_requests_total[$__rate_interval]))",
          "legendFormat": "{{route_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Duration p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(conduitsharp_gateway_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(conduitsharp_gateway_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(conduitsharp_gateway_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(increase(conduitsharp_gateway_requests_total[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(conduitsharp_gateway_errors_total[$__rate_interval]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Requests by Status Code",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum by (http_response_status_code) (increase(conduitsharp_gateway_requests_total[$__range]))",
          "legendFormat": "{{http_response_status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Requests by Route",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum by (route_id) (increase(conduitsharp_gateway_requests_total[$__range]))",
          "legendFormat": "{{route_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Traces",
      "type": "traces",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "uid": "tempo", "type": "tempo" },
      "options": { "dedupStrategy": "none" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{ resource.service.name = \"ConduitSharp.Gateway\" }",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Gateway Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "datasource": { "uid": "loki", "type": "loki" },
      "options": {
        "dedupStrategy": "none",
        "showTime": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false
      },
      "targets": [
        {
          "expr": "{service_name=\"ConduitSharp.Gateway\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
