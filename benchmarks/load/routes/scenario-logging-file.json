{
  "routes": [
    {
      "id": "bench-logging-file",
      "description": "Logging benchmark — captures request body to file asynchronously.",
      "route": { "match": { "path": "/{**catch-all}" } },
      "cluster": {
        "loadBalancingPolicy": "RoundRobin",
        "destinations": {
          "node-0": { "address": "http://upstream:8081" },
          "node-1": { "address": "http://upstream:8082" }
        }
      },
      "plugins": [
        { "name": "custom", "variant": "body-capture-file", "config": { "logPath": "/tmp/envoy-logs/conduit.json", "maxSize": 4096 } }
      ]
    }
  ]
}
