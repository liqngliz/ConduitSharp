{
  "routes": [
    {
      "id": "bench-logging",
      "description": "Logging benchmark — captures request body to Loki.",
      "route": { "match": { "path": "/{**catch-all}" } },
      "cluster": {
        "loadBalancingPolicy": "RoundRobin",
        "destinations": {
          "node-0": { "address": "http://upstream:8081" },
          "node-1": { "address": "http://upstream:8082" }
        }
      },
      "plugins": [
        { "name": "custom", "variant": "body-capture", "config": { "maxSize": 4096, "logLevel": "Warning" } }
      ]
    }
  ]
}
