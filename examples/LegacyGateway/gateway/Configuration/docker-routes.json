{
  "routes": [
    {
      "id": "inventory-service",
      "description": "Inventory API — API key auth, rate limited, round-robin across two nodes",
      "circuitBreaker": { "threshold": 2, "cooldownMs": 30000 },
      "route": {
        "match": {
          "path": "/api/inventory/{**rest}",
          "methods": ["GET", "POST"]
        }
      },
      "cluster": {
        "loadBalancingPolicy": "RoundRobin",
        "destinations": {
          "node-0": { "address": "http://inventory-svc-1:5101" },
          "node-1": { "address": "http://inventory-svc-2:5101" }
        },
        "httpRequest": {
          "activityTimeout": "00:00:05"
        }
      },
      "swagger": {
        "fetchFrom": "http://inventory-svc-1:5101/openapi/v1.json"
      },
      "plugins": [
        {
          "name": "api-key-auth",
          "order": 1,
          "enabled": true,
          "config": {
            "header": "X-Api-Key",
            "keys": ["demo-api-key-conduitsharp-example"]
          }
        },
        {
          "name": "rate-limit",
          "order": 2,
          "enabled": true,
          "config": {
            "windowSeconds": 60,
            "maxRequests": 100
          }
        },
        {
          "name": "custom",
          "variant": "body-capture",
          "order": 10,
          "enabled": true,
          "config": {
            "maxSize": 1024
          }
        },
        {
          "name": "http-proxy",
          "order": 99,
          "enabled": true
        }
      ]
    },
    {
      "id": "order-service",
      "description": "Order API — JWT (HS256) auth, forwarded to order service",
      "route": {
        "match": {
          "path": "/api/orders/{**rest}",
          "methods": ["GET", "POST"]
        }
      },
      "cluster": {
        "loadBalancingPolicy": "RoundRobin",
        "destinations": {
          "node-0": { "address": "http://order-svc:5201" }
        },
        "httpRequest": {
          "activityTimeout": "00:00:05"
        }
      },
      "swagger": {
        "fetchFrom": "http://order-svc:5201/openapi/v1.json"
      },
      "plugins": [
        {
          "name": "jwt-auth",
          "order": 1,
          "enabled": true,
          "config": {
            "signingKey": "ZGVtby1zaWduaW5nLWtleS1jb25kdWl0c2hhcnAtZXhhbXBsZS0zMmNo",
            "issuer":     "conduitsharp-demo",
            "audience":   "conduitsharp-demo"
          }
        },
        {
          "name": "custom",
          "variant": "body-capture",
          "order": 10,
          "enabled": true,
          "config": {
            "maxSize": 1024
          }
        },
        {
          "name": "http-proxy",
          "order": 99,
          "enabled": true
        }
      ]
    },
    {
      "id": "upload-service",
      "description": "Upload API — streamed directly without buffering; body-capture-streaming logs a bounded prefix off the tee",
      "route": {
        "match": {
          "path": "/api/upload/{**rest}",
          "methods": ["POST", "PUT"]
        }
      },
      "streamOnly": true,
      "cluster": {
        "loadBalancingPolicy": "RoundRobin",
        "destinations": {
          "node-0": { "address": "http://order-svc:5201" }
        },
        "httpRequest": {
          "activityTimeout": "00:00:15"
        }
      },
      "plugins": [
        {
          "name": "custom",
          "variant": "body-capture-streaming",
          "order": 10,
          "enabled": true,
          "config": {
            "maxSize": 1024
          }
        },
        {
          "name": "http-proxy",
          "order": 99,
          "enabled": true
        }
      ]
    },
    {
      "id": "erp-report",
      "description": "ERP erp report — JWT auth + role-based access, rate limited, cached 60s, executed via PowerShell plugin",
      "route": {
        "match": {
          "path": "/erp/reports/summary",
          "methods": ["GET"]
        }
      },
      "cluster": null,
      "swagger": {
        "specFile": "specs/erp-report.json"
      },
      "plugins": [
        {
          "name": "jwt-auth",
          "order": 1,
          "enabled": true,
          "config": {
            "signingKey": "ZGVtby1zaWduaW5nLWtleS1jb25kdWl0c2hhcnAtZXhhbXBsZS0zMmNo",
            "issuer":     "conduitsharp-demo",
            "audience":   "conduitsharp-demo",
            "requiredClaims": [
              { "claim": "role", "anyOf": ["analyst", "erp-admin"] }
            ]
          }
        },
        {
          "name": "rate-limit",
          "order": 2,
          "enabled": true,
          "config": {
            "windowSeconds": 3600,
            "maxRequests": 100
          }
        },
        {
          "name": "cache",
          "order": 3,
          "enabled": true,
          "config": {
            "ttlSeconds": 60
          }
        },
        {
          "name": "custom",
          "variant": "power-shell",
          "order": 99,
          "enabled": true,
          "config": {
            "scriptPath": "scripts/Get-ErpReport.ps1"
          }
        }
      ]
    },
    {
      "id": "error-demo",
      "description": "Demonstrates a 502 Bad Gateway from an unreachable upstream — used by the Grafana E2E suite to verify error-level request logs reach Loki",
      "route": {
        "match": {
          "path": "/error-demo",
          "methods": ["GET"]
        }
      },
      "cluster": {
        "loadBalancingPolicy": "RoundRobin",
        "destinations": {
          "node-0": { "address": "http://nonexistent-upstream:9999" }
        },
        "httpRequest": {
          "activityTimeout": "00:00:01"
        }
      },
      "plugins": [
        {
          "name": "http-proxy",
          "order": 99,
          "enabled": true
        }
      ]
    },
    {
      "id": "health",
      "description": "Health check — passthrough, no auth, no policies",
      "route": {
        "match": {
          "path": "/health",
          "methods": ["GET"]
        }
      },
      "swagger": {
        "specFile": "specs/health.json"
      },
      "cluster": {
        "loadBalancingPolicy": "RoundRobin",
        "destinations": {
          "node-0": { "address": "http://inventory-svc-1:5101" }
        },
        "httpRequest": {
          "activityTimeout": "00:00:02"
        }
      },
      "plugins": [
        {
          "name": "http-proxy",
          "order": 99,
          "enabled": true
        }
      ]
    }
  ]
}
