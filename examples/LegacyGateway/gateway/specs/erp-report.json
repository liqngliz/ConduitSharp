{
  "openapi": "3.0.1",
  "info": {
    "title": "Erp — Value Report",
    "version": "v1",
    "description": "ERP value report executed via PowerShell plugin. No upstream service — ConduitSharp runs the .ps1 script and returns the result directly. Requires a valid JWT (HS256, issuer: conduitsharp-demo)."
  },
  "paths": {
    "/erp/reports/summary": {
      "get": {
        "tags": ["Erp"],
        "summary": "Get value report",
        "description": "Returns a cached (60s TTL) Q2 value breakdown by product, generated by a PowerShell script. Auth: Bearer JWT.",
        "security": [
          { "Bearer": [] }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Value report generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErpReport"
                },
                "example": {
                  "generatedAt": "2026-06-29T10:00:00Z",
                  "reportingPeriod": "Q2-2026",
                  "currency": "USD",
                  "averageValue": 0.458,
                  "values": [
                    { "product": "Widget A",     "category": "Hardware", "revenue": 142000, "cogs": 82360,  "value": 0.42, "trend": "up"   },
                    { "product": "Widget B",     "category": "Hardware", "revenue": 57000,  "cogs": 39330,  "value": 0.31, "trend": "flat" },
                    { "product": "Gadget X",     "category": "Software", "revenue": 98000,  "cogs": 39200,  "value": 0.60, "trend": "up"   },
                    { "product": "Gadget Y Pro", "category": "Software", "revenue": 210000, "cogs": 105000, "value": 0.50, "trend": "down" }
                  ]
                }
              }
            }
          },
          "401": { "description": "Missing or invalid JWT" },
          "429": { "description": "Rate limit exceeded (100 req/hour)" },
          "500": { "description": "PowerShell script error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Generate a demo token with: pwsh generate-token.ps1"
      }
    },
    "schemas": {
      "ErpReport": {
        "type": "object",
        "properties": {
          "generatedAt":      { "type": "string", "format": "date-time" },
          "reportingPeriod":  { "type": "string", "example": "Q2-2026" },
          "currency":         { "type": "string", "example": "USD" },
          "averageValue":    { "type": "number", "format": "double" },
          "values": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductValue" }
          }
        }
      },
      "ProductValue": {
        "type": "object",
        "properties": {
          "product":   { "type": "string" },
          "category":  { "type": "string" },
          "revenue":   { "type": "number" },
          "cogs":      { "type": "number" },
          "value":    { "type": "number", "format": "double" },
          "trend":     { "type": "string", "enum": ["up", "flat", "down"] }
        }
      }
    }
  }
}
